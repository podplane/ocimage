{
  "name": "ocimage-hono-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:node": "tsx watch src/index.ts",
    "dev:bun": "bun --watch src/index.ts",
    "build:node": "esbuild src/index.ts --bundle --platform=node --format=esm --target=es2022 --outfile=dist/server.js",
    "build:bun": "bun build src/index.ts --target=bun --outfile=dist/server.js",
    "start:node": "node dist/server.js",
    "start:bun": "bun dist/server.js"
  },
  "dependencies": {
    "@hono/node-server": "1.19.6",
    "hono": "4.11.7"
  },
  "devDependencies": {
    "@types/bun": "1.3.5",
    "@types/node": "26.1.0",
    "esbuild": "0.27.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  }
}
