ARG OCIMAGE_STORE_URL=
FROM ${OCIMAGE_STORE_URL}php/base:8.4-frankenphp

# WARNING: Not safe for production! These are demo-only defaults. Do not copy
# the fixed APP_KEY or image-local file cache/session settings into production;
# inject secrets and runtime configuration from the deployment environment instead.
ENV APP_ENV=production \
    APP_DEBUG=false \
    APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA= \
    CACHE_STORE=file \
    LOG_CHANNEL=stderr \
    SESSION_DRIVER=file \
    SERVER_NAME=:8080 \
    PORT=8080

WORKDIR /app

COPY --chown=nonroot:nonroot demo/app app
COPY --chown=nonroot:nonroot demo/bootstrap bootstrap
COPY --chown=nonroot:nonroot demo/config config
COPY --chown=nonroot:nonroot demo/public public
COPY --chown=nonroot:nonroot demo/resources resources
COPY --chown=nonroot:nonroot demo/routes routes
COPY --chown=nonroot:nonroot demo/storage storage
COPY --chown=nonroot:nonroot demo/vendor vendor
COPY --chown=nonroot:nonroot demo/artisan demo/composer.json demo/composer.lock ./

CMD ["frankenphp", "php-server", "--listen", ":8080", "--root", "public"]
